#!/usr/bin/env bash
# Update local hostname resolution entries.

set -euo pipefail

tmp_file=$(mktemp)

awk '
	/^[[:space:]]*#/ { print; next }
	$0 ~ /(^|[[:space:]])localhost([[:space:]]|$)/ {
		print "127.0.0.2 localhost"
		localhost_found = 1
		next
	}
	$0 ~ /(^|[[:space:]])facebook\.com([[:space:]]|$)/ {
		print "8.8.8.8 facebook.com"
		facebook_found = 1
		next
	}
	{ print }
	END {
		if (!localhost_found) {
			print "127.0.0.2 localhost"
		}
		if (!facebook_found) {
			print "8.8.8.8 facebook.com"
		}
	}
' /etc/hosts > "$tmp_file"

cat "$tmp_file" > /etc/hosts
rm -f "$tmp_file"
